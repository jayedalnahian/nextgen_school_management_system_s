model Parent {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  phone            String    @unique
  address          String    @db.Text
  occupation       String?
  image            String?
  stripeCustomerId String?   @unique
  students         Student[]
  payments         Payment[]
}
